# FinSight Backend — Production Environment Template
# Copy this to .env and fill in the values for production deployment

# Required: Your Anthropic API key
# Get it from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required: CORS origins (JSON array format)
# Update with your deployed frontend URL after Vercel deployment
# Format: ["https://domain1.com", "https://domain2.com"]
CORS_ORIGINS=["https://your-frontend.vercel.app"]

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Maximum PDF upload size in MB
MAX_FILE_SIZE_MB=10
