{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "context": "./backend"
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port 8000",
    "numReplicas": 1
  },
  "variables": {
    "ANTHROPIC_API_KEY": {
      "description": "Your Anthropic API key for Claude access",
      "value": ""
    },
    "CORS_ORIGINS": {
      "description": "Comma-separated list of allowed CORS origins (JSON array format)",
      "value": "[\"https://your-frontend.vercel.app\"]"
    },
    "LOG_LEVEL": {
      "value": "INFO"
    },
    "MAX_FILE_SIZE_MB": {
      "value": "10"
    }
  }
}
